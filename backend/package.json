{
  "name": "gather-backend",
  "description": "Gather Backend - Social Scheduling API",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "format": "npx prettier --write \"lambdas/**/*.{ts,json}\" \"src/**/*.{ts,json}\"",
    "check": "npx prettier --check \"lambdas/**/*.{ts,json}\" \"src/**/*.{ts,json}\"",
    "pre-commit": "lint-staged",
    "pre-push": "npm run test",
    "prepre-push": "npm run pre-commit",
    "test": "vitest --coverage",
    "test:w": "npm run test -- --watch",
    "test:ci": "vitest --coverage --silent false --verbose",
    "deploy": "serverless deploy --stage dev",
    "deploy:prod": "serverless deploy --stage prod",
    "offline": "serverless offline start",
    "logs": "serverless logs -f"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/aws-lambda": "^8.10.160",
    "@types/node": "^24.10.1",
    "aws-sdk-client-mock": "^4.1.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "eslint-config-love": "^145.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.0",
    "serverless": "^4.31.0",
    "serverless-offline": "^14.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "vitest": "^4.0.17"
  },
  "lint-staged": {
    "*.ts": [
      "npx eslint --fix",
      "npx prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.971.0",
    "@aws-sdk/client-sns": "^3.971.0",
    "@aws-sdk/util-dynamodb": "^3.971.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.5"
  }
}
