{
  "name": "gather-backend",
  "description": "Gather Backend - Social Scheduling API",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint": "npx eslint . && tsc --noEmit",
    "lint:fix": "npx eslint . --fix",
    "format": "npx prettier --write \"lambdas/**/*.{ts,json}\" \"src/**/*.{ts,json}\"",
    "check": "npx prettier --check \"lambdas/**/*.{ts,json}\" \"src/**/*.{ts,json}\"",
    "deploy": "serverless deploy --stage dev",
    "deploy:prod": "serverless deploy --stage prod",
    "offline": "serverless offline start",
    "generate:openapi": "tsx --env-file=.env scripts/generate-openapi.ts",
    "db:generate": "drizzle-kit generate",
    "db:generate:prod": "DB_STAGE=prod drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env scripts/migrate.ts",
    "db:migrate:prod": "DB_STAGE=prod tsx --env-file=.env scripts/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:push:prod": "DB_STAGE=prod drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:studio:prod": "DB_STAGE=prod drizzle-kit studio",
    "script:seed": "tsx --env-file=.env scripts/seed-mock-data.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^24.13.2",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "serverless": "^4.37.0",
    "serverless-offline": "^14.7.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "lint-staged": {
    "*.ts": [
      "npx eslint --fix",
      "npx prettier --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.80",
    "@aws-sdk/client-ses": "^3.1066.0",
    "@googleapis/calendar": "^15.0.0",
    "@hono/zod-openapi": "^1.4.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@microsoft/microsoft-graph-types": "^2.43.1",
    "@neondatabase/serverless": "^1.1.0",
    "ai": "^6.0.200",
    "drizzle-orm": "^0.45.2",
    "expo-server-sdk": "^5.0.0",
    "hono": "^4.12.25",
    "libphonenumber-js": "^1.13.6",
    "zod": "^4.4.3"
  }
}
