{
  "name": "gather-backend",
  "description": "Gather Backend - Social Scheduling API",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint": "npx eslint . && tsc --noEmit",
    "lint:fix": "npx eslint . --fix",
    "format": "npx prettier --write \"lambdas/**/*.{ts,json}\" \"src/**/*.{ts,json}\"",
    "check": "npx prettier --check \"lambdas/**/*.{ts,json}\" \"src/**/*.{ts,json}\"",
    "pre-commit": "lint-staged",
    "pre-push": "npm run test",
    "prepre-push": "npm run pre-commit",
    "test": "vitest --coverage",
    "test:w": "npm run test -- --watch",
    "test:ci": "vitest --coverage --silent false --verbose",
    "deploy": "serverless deploy --stage dev",
    "deploy:prod": "serverless deploy --stage prod",
    "offline": "serverless offline start",
    "generate:openapi": "tsx --env-file=.env scripts/generate-openapi.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env scripts/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "script:seed": "tsx --env-file=.env scripts/seed-mock-data.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/aws-lambda": "^8.10.160",
    "@types/node": "^24.10.1",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.0",
    "serverless": "^4.31.0",
    "serverless-offline": "^14.4.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "vitest": "^4.0.17"
  },
  "lint-staged": {
    "*.ts": [
      "npx eslint --fix",
      "npx prettier --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.24",
    "@googleapis/calendar": "^14.2.0",
    "@hono/zod-openapi": "^1.2.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@microsoft/microsoft-graph-types": "^2.43.1",
    "@neondatabase/serverless": "^1.0.2",
    "ai": "^6.0.78",
    "drizzle-orm": "^0.45.1",
    "expo-server-sdk": "^5.0.0",
    "hono": "^4.11.4",
    "zod": "^4.3.5"
  }
}
