{
  "name": "gather",
  "main": "expo-router/entry",
  "version": "1.1.1",
  "scripts": {
    "lint": "expo lint && tsc --noEmit",
    "format": "npx prettier --write \"{app,components,lib}/**/*.{ts,tsx,js,json}\"",
    "check": "npx prettier --check \"{app,components,lib}/**/*.{ts,tsx,js,json}\"",
    "start": "expo start",
    "prebuild:development": "APP_ENV=development expo prebuild --clean --platform ios",
    "prebuild:release": "expo prebuild --clean --platform ios",
    "build:development": "APP_ENV=development expo run:ios --device",
    "build:release": "expo run:ios --configuration Release --device",
    "generate:api": "openapi-ts",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-ai/apple": "^0.12.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@tamagui/animations-react-native": "^1.144.4",
    "@tamagui/config": "^1.144.4",
    "@tamagui/linear-gradient": "^1.144.4",
    "@tamagui/lucide-icons": "^1.144.4",
    "@tanstack/react-query": "^5.101.0",
    "ai": "^6.0.200",
    "buffer": "^6.0.3",
    "expo": "^56.0.0",
    "expo-apple-authentication": "~56.0.4",
    "expo-calendar": "~56.0.8",
    "expo-camera": "~56.0.8",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.18",
    "expo-contacts": "~56.0.9",
    "expo-dev-client": "~56.0.20",
    "expo-font": "~56.0.6",
    "expo-glass-effect": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-location": "~56.0.17",
    "expo-notifications": "~56.0.17",
    "expo-router": "~56.2.10",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "lodash.debounce": "^4.0.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-maps": "1.27.2",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "tamagui": "^1.144.4"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.98.2",
    "@types/lodash.debounce": "^4.0.9",
    "@types/react": "~19.2.10",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript": "~6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npx eslint --fix",
      "npx prettier --write"
    ]
  },
  "private": true
}
