{
  "name": "gather",
  "main": "expo-router/entry",
  "version": "1.1.1",
  "scripts": {
    "lint": "expo lint && tsc --noEmit",
    "format": "npx prettier --write \"{app,components,lib}/**/*.{ts,tsx,js,json}\"",
    "check": "npx prettier --check \"{app,components,lib}/**/*.{ts,tsx,js,json}\"",
    "start": "expo start",
    "prebuild:development": "APP_ENV=development expo prebuild --clean --platform ios",
    "prebuild:release": "expo prebuild --clean --platform ios",
    "build:development": "APP_ENV=development expo run:ios --device",
    "build:release": "expo run:ios --configuration Release --device",
    "generate:api": "openapi-ts",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@hey-api/client-fetch": "^0.13.1",
    "@react-native-ai/apple": "^0.12.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.8",
    "@tamagui/animations-react-native": "^1.144.3",
    "@tamagui/config": "^1.144.3",
    "@tamagui/linear-gradient": "^1.144.3",
    "@tamagui/lucide-icons": "^1.144.3",
    "@tanstack/react-query": "^5.90.20",
    "ai": "^6.0.111",
    "buffer": "^6.0.3",
    "expo": "^55.0.0",
    "expo-apple-authentication": "~55.0.8",
    "expo-calendar": "~55.0.9",
    "expo-clipboard": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.7",
    "expo-haptics": "~55.0.8",
    "expo-linear-gradient": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-location": "~55.1.2",
    "expo-notifications": "~55.0.10",
    "expo-router": "~55.0.3",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "lodash.debounce": "^4.0.8",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-maps": "1.26.20",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "tamagui": "^1.144.3"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.90.10",
    "@types/lodash.debounce": "^4.0.9",
    "@types/react": "~19.2.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npx eslint --fix",
      "npx prettier --write"
    ]
  },
  "private": true
}
